# ── MongoDB ─────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Replace <username>, <password>, <cluster>, and <dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (your Vercel URL goes here)
ALLOWED_ORIGIN=https://your-sudoku-app.vercel.app
